{
  "expo": {
    "name": "Hunch",
    "slug": "hunch-inc",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/hunch.jpg",
    "scheme": "hunch",
    "userInterfaceStyle": "automatic",
    "deepLinking": {
      "enabled": true,
      "scheme": "hunch"
    },
    "splash": {
      "image": "./assets/hunch.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FFE500"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "bundleIdentifier": "com.hunch.run",
      "splash": {
        "image": "./assets/hunch.jpg",
        "resizeMode": "contain",
        "backgroundColor": "#FFE500",
        "tabletImage": "./assets/hunch.jpg"
      },
      "associatedDomains": [
        "webcredentials:hunch.run",
        "webcredentials:hunch.run"
      ],
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true
        },
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/hunch.jpg",
        "backgroundColor": "#FFE500"
      },
      "package": "com.hunch.run"
    },
    "extra": {
      "privyAppId": "cmiq91u0h006jl70cuyb6az3f",
      "privyClientId": "client-WY6TPKUhXLQRQM8fGYrMc36tyhszpq7DLgNyaUgSKrPo6",
      "passkeyAssociatedDomain": "https://hunch.run",
      "router": {},
      "eas": {
        "projectId": "c86e43bc-c659-47ec-8505-1868167e1fbf"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "17.5"
          },
          "android": {
            "compileSdkVersion": 35
          }
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "defaultChannel": "hunch-default",
          "color": "#FFE500"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
